# Dev: leave unset. The Vite proxy in vite.config.ts forwards /api to
# http://127.0.0.1:8000, so the frontend uses "/api/v1" as the base URL.
#
# Vercel production: set this to the Railway backend URL, e.g.
#   VITE_API_BASE_URL=https://pmo-agent-backend.up.railway.app/api/v1
VITE_API_BASE_URL=/api/v1
