# Path to the SQLite database. Defaults to repo-root pmo_data.db.
# DB_PATH=/Users/brettanderson/Desktop/ETE PMO/pmo_data.db

# Snapshot store (change detection).
# SNAPSHOT_DB_PATH=/Users/brettanderson/Desktop/ETE PMO/pmo_snapshots.db

# Comma-separated CORS origins for the React dev server + Vercel deploy.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Anthropic API key for the /agent/chat endpoint.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Jira API token (format user@company.com:api-token) for /jira/sync.
# JIRA_API_TOKEN=
